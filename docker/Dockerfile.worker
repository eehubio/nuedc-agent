# 后台 Worker 镜像。
#
# Worker 必须独立于 Vercel 部署：Vercel 只跑 Web（Serverless，无常驻进程），
# agent_tasks 队列需要一个常驻消费者。本镜像即该消费者。
#
# 构建：
#   docker build -f docker/Dockerfile.worker -t nuedc-worker:latest .
#
# 运行（至少需要 DATABASE_URL，与 Web 指向同一个库）：
#   docker run -d --name nuedc-worker --restart unless-stopped \
#     -e DATABASE_URL='postgresql://...' \
#     -e GEMINI_API_KEY='...' \
#     -e WORKER_HEAVY_SLOTS=2 -e WORKER_LIGHT_SLOTS=6 \
#     nuedc-worker:latest
#
# 健康检查：Worker 是常驻进程而非 HTTP 服务，容器健康以「心跳是否新鲜」为准。
# 心跳写入 worker_heartbeats 表，由 Web 的 /api/ready 汇总告警。
# 容器内自检脚本 scripts/worker-healthcheck.mts 直接查库判断本 worker_id 的心跳。

FROM node:20-bookworm-slim

# tini 作为 PID 1，保证 SIGTERM 正确转发给 Node（优雅退出、释放租约）
RUN apt-get update && apt-get install -y --no-install-recommends tini \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 依赖层单独缓存
COPY package.json package-lock.json* ./
RUN npm ci || npm install

COPY . .

# 非 root 运行
RUN useradd -r -u 10001 -m worker && chown -R worker:worker /app
USER worker

ENV NODE_ENV=production \
    WORKER_HEAVY_SLOTS=2 \
    WORKER_LIGHT_SLOTS=6 \
    WORKER_POLL_MS=1500

# 心跳新鲜度自检：超过阈值未续期即判定不健康，由编排系统重启
HEALTHCHECK --interval=60s --timeout=15s --start-period=30s --retries=3 \
  CMD ["npx", "tsx", "scripts/worker-healthcheck.mts"]

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["npm", "run", "worker"]
