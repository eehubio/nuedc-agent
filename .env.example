# ===== 数据库（生产环境用 Turso，本地开发用文件库）=====
# 本地开发可留空，默认 file:local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ===== 大模型（三选一，或都配上按 Agent 路由）=====
LLM_PROVIDER=anthropic            # anthropic | openai | gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenAI 兼容端点（可指向 DeepSeek / Qwen / Moonshot 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===== 嵌入与鉴权 =====
# 允许嵌入本应用的父页面来源（ezPLM 域名）
ALLOWED_EMBED_ORIGIN=https://www.ezplm.cn https://*.ezplm.cn
ALLOWED_API_ORIGIN=*
# ezPLM 服务端调用本应用 API 时使用的共享密钥
EZPLM_API_KEY=change-me
# 管理员密钥（模块审核 / 认证）
ADMIN_API_KEY=change-me-admin
