# ============ 数据库 ============
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ============ 管理与账户 ============
ADMIN_API_KEY=
EZPLM_API_KEY=
PAID_ACCESS_CODE=

# ============ 模型网关：主模型 ============
# 支持的 Provider：gemini / qwen / deepseek / glm / moonshot / custom
MODEL_PROVIDER_PRIMARY=gemini
# 容灾链（逗号分隔，按顺序尝试）
MODEL_PROVIDER_FALLBACK=qwen,deepseek
# 低成本任务优先链（留空则按各 Provider 单价自动排序）
MODEL_PROVIDER_CHEAP=
# 多模态任务（PDF/OCR）优先链（留空则自动选有 vision 能力的）
MODEL_PROVIDER_VISION=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_VISION=gemini-2.5-flash

# 通义千问（阿里云 DashScope，OpenAI 兼容模式）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_TEXT=qwen-plus
QWEN_MODEL_VISION=qwen-vl-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_TEXT=deepseek-chat

# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_TEXT=glm-4-flash
GLM_MODEL_VISION=glm-4v-flash

# Kimi
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL_TEXT=moonshot-v1-8k

# 任意其他厂商 / 自建网关（只要兼容 OpenAI /chat/completions）
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL_TEXT=
CUSTOM_MODEL_VISION=

# ============ 成本与容量治理 ============
PER_USER_DAILY_BUDGET_USD=
PER_PROJECT_DAILY_BUDGET_USD=
GLOBAL_DAILY_BUDGET_USD=
MAX_GLOBAL_HEAVY_CONCURRENCY=20
MAX_PER_USER_CONCURRENCY=1
QUEUE_WARNING_THRESHOLD=20

# 系统模式：NORMAL / DEGRADED / RULES_ONLY / READ_ONLY（留空则读数据库配置）
SYSTEM_MODE=

# ============ 开发与压测 ============
# 设为 1 启用 mock provider（不产生真实费用）
ENABLE_MOCK_PROVIDER=
MOCK_LATENCY_MS=200
MOCK_FAIL_RATE=0
# 设为 0 可回滚到网关前的直连实现
GATEWAY_ENABLED=1

# ============ 后台 Worker（常驻进程）============
# 部署：npm run worker  /  pm2 start npm --name nuedc-worker -- run worker
WORKER_ID=
WORKER_HEAVY_SLOTS=2
WORKER_LIGHT_SLOTS=6
WORKER_POLL_MS=1500
# 未部署 Worker 时的降级：允许前端点火同步执行
ALLOW_INLINE_EXECUTE=
# 临时放开普通用户指定 Provider（默认禁止）
ALLOW_USER_PROVIDER_HINT=

# ============ 数据库驱动 ============
# 留空自动判断：*.neon.tech → neon(HTTP)，其余 → postgres_pool(连接池)
# 自建 Postgres / Docker / CI 会自动走连接池，无需设置
DB_DRIVER=
PG_POOL_MAX=10
