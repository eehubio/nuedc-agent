# ===== 数据库（Neon Postgres）=====
# 在 Neon 控制台复制连接串。Web 与 Worker 必须指向同一个库。
DATABASE_URL=

# 数据库驱动。不配置时按 DATABASE_URL 自动判断，但生产建议显式声明：
#   neon_http     Neon 云端（Vercel 生产用这个，HTTP 驱动，Serverless 友好）
#   postgres_pool 标准 Postgres（CI、自建库，node-postgres TCP 连接池）
#   pglite        进程内 Postgres（单元测试）
# 注意：显式值优先于自动判断，取值非法会直接抛错而不是静默回退。
DB_DRIVER=neon_http

# 连接池参数（仅 postgres_pool / neon Pool 事务路径生效）
# DB_POOL_MAX=10
# DB_POOL_IDLE_MS=30000
# DB_POOL_CONN_TIMEOUT_MS=10000

# ===== 大模型（三选一，或都配上按 Agent 路由）=====
LLM_PROVIDER=anthropic            # anthropic | openai | gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenAI 兼容端点（可指向 DeepSeek / Qwen / Moonshot 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===== 嵌入与鉴权 =====
# 允许嵌入本应用的父页面来源（ezPLM 域名）
ALLOWED_EMBED_ORIGIN=https://www.ezplm.cn https://*.ezplm.cn
ALLOWED_API_ORIGIN=*
# ezPLM 服务端调用本应用 API 时使用的共享密钥
EZPLM_API_KEY=change-me
# 管理员密钥（模块审核 / 认证）
ADMIN_API_KEY=change-me-admin
