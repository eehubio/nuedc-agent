{
  "name": "nuedc-agent",
  "version": "0.1.0",
  "private": true,
  "description": "NUEDC Agent — 电赛智能体：赛题理解 / 题目预测 / 模块数据库 / 方案生成 / BOM / 代码生成 / LabSight 调试 / 报告生成。可嵌入 ezPLM，也可独立部署到 Vercel。",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:init": "tsx scripts/init-db.mts",
    "db:seed": "tsx scripts/seed.mts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "build:runner": "tsx scripts/build-runner.mts",
    "e2e": "tsx scripts/e2e-smoke.mts",
    "verify:docx": "tsx scripts/verify-docx.mts",
    "load-test": "tsx scripts/load-test.mts",
    "worker": "tsx scripts/agent-worker.mts",
    "module-images": "tsx scripts/module-images.mts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/pg": "^8.20.0",
    "docx": "^9.7.1",
    "marked": "^18.0.7",
    "next": "^14.2.33",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}